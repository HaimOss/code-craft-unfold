{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://lvzfgjqepuvuezoxmsdk.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "wonderjourney-mcp",
      "version": "0.1.0",
      "title": "WonderJourney"
    },
    "tools": [
      {
        "name": "list_trips",
        "title": "List trips",
        "description": "List the signed-in user's trips (id, name, destination, dates, status, budget).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "status": {
              "description": "Optional trip status filter, e.g. 'Planning 📝'",
              "type": "string"
            },
            "limit": {
              "description": "Max rows to return (default 50)",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_trip",
        "title": "Get trip",
        "description": "Fetch a single trip with all its events (itinerary).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "trip_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The trip's UUID."
            }
          },
          "required": [
            "trip_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "create_trip",
        "title": "Create trip",
        "description": "Create a new trip for the signed-in user.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "description": "Trip name."
            },
            "destination": {
              "type": "string"
            },
            "start_date": {
              "type": "string",
              "description": "ISO date, e.g. 2026-05-10"
            },
            "end_date": {
              "type": "string",
              "description": "ISO date, e.g. 2026-05-14"
            },
            "base_currency": {
              "description": "ISO currency, default USD",
              "type": "string"
            },
            "status": {
              "description": "Trip status, e.g. 'Planning 📝'",
              "type": "string"
            },
            "budget": {
              "type": "number"
            }
          },
          "required": [
            "name",
            "start_date",
            "end_date"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "add_event",
        "title": "Add event to trip",
        "description": "Add an itinerary event (flight, hotel, activity, food, etc.) to a trip.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "trip_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "date": {
              "type": "string",
              "description": "ISO date."
            },
            "time": {
              "description": "HH:MM",
              "type": "string"
            },
            "end_time": {
              "type": "string"
            },
            "category": {
              "type": "string",
              "description": "e.g. 'Activity 🎭', 'Food 🍽️', 'Flights ✈️'"
            },
            "title": {
              "type": "string",
              "minLength": 1
            },
            "amount": {
              "type": "number"
            },
            "currency": {
              "type": "string"
            },
            "payment_method": {
              "description": "Credit | Debit | Cash | Other",
              "type": "string"
            },
            "notes": {
              "type": "string"
            }
          },
          "required": [
            "trip_id",
            "date",
            "category",
            "title"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_checklist",
        "title": "List trip checklist",
        "description": "List checklist items for a trip.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "trip_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "only_open": {
              "description": "If true, return only incomplete items.",
              "type": "boolean"
            }
          },
          "required": [
            "trip_id"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
